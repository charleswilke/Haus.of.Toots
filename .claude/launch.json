{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Vercel Dev Server",
      "runtimeExecutable": "vercel",
      "runtimeArgs": ["dev", "--listen", "0.0.0.0"],
      "port": 3000
    },
    {
      "name": "Python HTTP Server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    }
  ]
}
